{
  "name": "ylsalame/laravel-use-cases",
  "description": "A reusable UseCase pattern implementation for Laravel applications, including a base UseCase, class inference helper, execution context and an extendable controller.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "use case",
    "usecase",
    "application service",
    "clean architecture"
  ],
  "authors": [
    {
      "name": "Yuri Salame"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/routing": "^10.0|^11.0|^12.0",
    "illuminate/validation": "^10.0|^11.0|^12.0",
    "illuminate/database": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "orchestra/testbench": "^8.0|^9.0"
  },
  "autoload": {
    "psr-4": {
      "Ylsalame\\LaravelUseCases\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ylsalame\\LaravelUseCases\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Ylsalame\\LaravelUseCases\\Providers\\LaravelUseCasesServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}

